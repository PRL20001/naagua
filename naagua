<title>Água Fácil – Água de Qualidade Entregue na Sua Casa</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'Segoe UI',Arial,sans-serif;color:#222}
  a{text-decoration:none;color:inherit}

  /* NAV */
  nav{display:flex;align-items:center;justify-content:space-between;padding:14px 6%;background:#fff;box-shadow:0 2px 8px rgba(0,0,0,.08);position:sticky;top:0;z-index:100}
  .logo{display:flex;align-items:center;gap:8px}
  .logo svg{width:38px;height:38px}
  .logo-text{line-height:1.1}
  .logo-text strong{display:block;font-size:1.25rem;color:#0047AB;letter-spacing:.5px}
  .logo-text span{font-size:.7rem;color:#0047AB;letter-spacing:2px}
  .nav-links{display:flex;gap:32px;list-style:none}
  .nav-links a{font-size:.88rem;font-weight:600;color:#333;border-bottom:2px solid transparent;padding-bottom:2px;transition:.2s}
  .nav-links a.active,.nav-links a:hover{color:#0047AB;border-color:#0047AB}
  .btn-nav{background:#0047AB;color:#fff;border:none;border-radius:6px;padding:10px 20px;font-size:.88rem;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:7px;transition:.2s}
  .btn-nav:hover{background:#003080}

  /* HERO */
  .hero{background:linear-gradient(120deg,#0047AB 55%,#3a9bd5 100%);padding:60px 6%;display:flex;align-items:center;justify-content:space-between;gap:32px;overflow:hidden;position:relative}
  .hero-text{flex:1;color:#fff;max-width:460px}
  .hero-text h1{font-size:3rem;font-weight:900;line-height:1.1;text-transform:uppercase;margin-bottom:10px}
  .hero-text h2{font-size:1.4rem;font-weight:700;text-transform:uppercase;margin-bottom:18px;opacity:.92}
  .hero-text p{font-size:.95rem;opacity:.88;margin-bottom:28px;line-height:1.6}
  .hero-badges{display:flex;gap:22px;margin-bottom:32px}
  .badge{display:flex;flex-direction:column;align-items:center;gap:4px;font-size:.7rem;font-weight:700;text-transform:uppercase;color:#fff;opacity:.9}
  .badge svg{width:28px;height:28px}
  .btn-whatsapp{background:#25D366;color:#fff;border:none;border-radius:8px;padding:14px 28px;font-size:1rem;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:10px;transition:.2s;box-shadow:0 4px 14px rgba(37,211,102,.35)}
  .btn-whatsapp:hover{background:#1ebe5d;transform:translateY(-2px)}
  .hero-img{flex:1;display:flex;justify-content:center;align-items:center;max-width:420px}
  .hero-img img{width:100%;max-width:400px;filter:drop-shadow(0 20px 40px rgba(0,0,0,.25));animation:float 3s ease-in-out infinite}
  @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-16px)}}

  /* SECTION TITLE */
  .section-title{text-align:center;margin-bottom:40px}
  .section-title h2{font-size:1.6rem;font-weight:900;text-transform:uppercase;color:#1a1a2e;letter-spacing:1px}
  .section-title .bar{width:48px;height:3px;background:#0047AB;margin:10px auto 0}

  /* COMO FUNCIONA */
  .como-funciona{padding:64px 6%;background:#fff}
  .steps{display:flex;align-items:flex-start;justify-content:center;gap:0;flex-wrap:wrap}
  .step{display:flex;flex-direction:column;align-items:center;text-align:center;max-width:160px}
  .step-icon{width:72px;height:72px;border-radius:50%;background:#0047AB;display:flex;align-items:center;justify-content:center;margin-bottom:14px}
  .step-icon svg{width:34px;height:34px;fill:#fff}
  .step h3{font-size:.8rem;font-weight:800;text-transform:uppercase;color:#0047AB;margin-bottom:6px}
  .step p{font-size:.8rem;color:#555;line-height:1.5}
  .arrow{font-size:1.6rem;color:#0047AB;margin:0 8px;padding-top:20px;opacity:.5}

  /* PRODUTOS */
  .produtos{padding:64px 6%;background:#f7f9fc}
  .produtos-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;margin-bottom:32px}
  .produto-card{background:#fff;border-radius:12px;border:1.5px solid #e4eaf3;padding:22px;display:flex;gap:18px;align-items:flex-start;transition:.2s}
  .produto-card:hover{box-shadow:0 8px 28px rgba(0,71,171,.13);transform:translateY(-3px)}
  .produto-img{width:90px;height:110px;object-fit:contain;flex-shrink:0}
  .produto-info h3{font-size:.95rem;font-weight:800;text-transform:uppercase;color:#1a1a2e;margin-bottom:6px}
  .produto-info p{font-size:.82rem;color:#666;margin-bottom:12px;line-height:1.5}
  .produto-preco{font-size:1.3rem;font-weight:900;color:#0047AB;margin-bottom:12px}
  .btn-pedir{background:#0047AB;color:#fff;border:none;border-radius:6px;padding:9px 18px;font-size:.82rem;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:.2s}
  .btn-pedir:hover{background:#003080}
  .btn-outline{display:block;width:fit-content;margin:0 auto;border:1.5px solid #0047AB;color:#0047AB;background:transparent;border-radius:8px;padding:12px 36px;font-size:.92rem;font-weight:700;cursor:pointer;transition:.2s}
  .btn-outline:hover{background:#0047AB;color:#fff}

  /* CTA BANNER */
  .cta-banner{background:#0047AB;padding:36px 6%;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap}
  .cta-banner-text{display:flex;align-items:center;gap:18px;color:#fff}
  .cta-banner-text svg{width:48px;height:48px;flex-shrink:0;fill:#fff;opacity:.9}
  .cta-banner-text h3{font-size:1.15rem;font-weight:800;text-transform:uppercase}
  .cta-banner-text p{font-size:.88rem;opacity:.85}
  .btn-whatsapp-green{background:#25D366;color:#fff;border:none;border-radius:8px;padding:14px 28px;font-size:.95rem;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:10px;transition:.2s}
  .btn-whatsapp-green:hover{background:#1ebe5d}

  /* FOOTER */
  footer{background:#0d2b6b;color:#fff;padding:52px 6% 24px}
  .footer-grid{display:grid;grid-template-columns:1.2fr 1fr 1fr;gap:40px;margin-bottom:36px}
  .footer-col h4{font-size:.85rem;font-weight:800;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:16px;color:#fff}
  .footer-col p{font-size:.82rem;color:#9bb4dd;line-height:1.7}
  .footer-col ul{list-style:none}
  .footer-col ul li{margin-bottom:8px}
  .footer-col ul li a{font-size:.82rem;color:#9bb4dd;transition:.2s}
  .footer-col ul li a:hover{color:#fff}
  .footer-contact-item{display:flex;align-items:center;gap:10px;margin-bottom:10px;font-size:.82rem;color:#9bb4dd}
  .footer-contact-item svg{width:18px;height:18px;fill:#25D366;flex-shrink:0}
  .footer-bottom{border-top:1px solid rgba(255,255,255,.12);padding-top:20px;text-align:center;font-size:.78rem;color:#7a9ac4}
  .footer-logo{display:flex;align-items:center;gap:8px;margin-bottom:14px}
  .footer-logo strong{font-size:1.1rem;color:#fff;letter-spacing:.5px}

  /* RESPONSIVE */
  @media(max-width:768px){
    .hero{flex-direction:column;padding:40px 5%;text-align:center}
    .hero-text h1{font-size:2rem}
    .hero-badges{justify-content:center}
    .hero-img{max-width:280px}
    .steps{gap:16px}
    .arrow{display:none}
    .footer-grid{grid-template-columns:1fr}
    .nav-links{display:none}
    .cta-banner{flex-direction:column;text-align:center}
  }
</style>
